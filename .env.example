# PikPak account (for first-time login inside container)
PIKPAK_USERNAME=
PIKPAK_PASSWORD=

# HTTP proxy for PikPak API (Python does not use Windows system proxy automatically)
# V2RayN example: PIKPAK_PROXY=http://127.0.0.1:10809
PIKPAK_PROXY=

# Session file — mount volume at /data/session and login once:
#   docker compose run --rm easy-pika-cli login -u USER -p PASS --session /data/session/session.json

# Download
DOWNLOAD_DIR=./downloads
DOWNLOAD_BACKEND=native
# DOWNLOAD_BACKEND=aria2
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_RPC_SECRET=easy_pika_secret

# Relay
RELAY_CLEANUP_CLOUD=true
RELAY_POLL_INTERVAL=10
RELAY_TIMEOUT=7200

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Comma-separated user IDs; empty = allow all
TELEGRAM_ALLOWED_USERS=

# AI HTTP API
AI_API_KEY=change-me
AI_API_HOST=0.0.0.0
AI_API_PORT=8765

# Optional: LLM parsing for Telegram / API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
